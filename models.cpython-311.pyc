{% extends 'base.html' %}
{% block content %}
<h1 class="text-2xl font-bold mb-4">All Submissions</h1>
<table class="bg-white w-full shadow rounded">
<tr class="bg-blue-200">
    <th class="p-2">Title</th>
    <th>Type</th>
    <th>Status</th>
</tr>
{% for item in data %}
<tr class="border-t">
    <td class="p-2">{{ item.title }}</td>
    <td>{{ item.type }}</td>
    <td>{{ item.status }}</td>
</tr>
{% endfor %}
</table>
{% endblock %}
